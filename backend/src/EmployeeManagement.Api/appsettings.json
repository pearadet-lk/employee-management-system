{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=EmployeeManagement;Username=ems_user;Password=ems_password"
  },
  "Jwt": {
    "Issuer": "EmployeeManagement",
    "Audience": "EmployeeManagementClient",
    "Key": "EmployeeManagementSuperSecretKey_ChangeInProduction_32chars!",
    "ExpiryMinutes": 60
  },
  "Cors": {
    "Origins": [ "http://localhost:4200" ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
